{
  "name": "football-fields-server",
  "version": "1.0.0",
  "description": "Football Fields API Server",
  "main": "index.js",
  "scripts": {
    "db:push:dev": "dotenv -e .env.development -- npx prisma db push",
    "db:push:prod": "dotenv -e .env.production -- npx prisma db push",
    "db:studio:dev": "dotenv -e .env.development -- npx prisma studio",
    "db:studio:prod": "dotenv -e .env.production -- npx prisma studio",
    "start": "node scripts/render-start.js",
    "dev": "nodemon index.js",
    "test": "jest --runInBand --detectOpenHandles",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "import:fields": "node scripts/importFieldsFromCsv.js ..\\weplay_courts_export.csv",
    "seed": "node prisma/seed.js",
    "clear-seed": "node prisma/clearSeed.js"
  },
  "keywords": [
    "football",
    "fields",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clerk/backend": "^2.29.2",
    "@clerk/express": "^1.7.23",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.1",
    "expo-server-sdk": "^5.0.0",
    "express": "^4.18.2",
    "firebase-admin": "^13.6.1",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "lru-cache": "^11.2.5",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "openai": "^6.17.0",
    "socket.io": "^4.7.5"
  },
  "optionalDependencies": {
    "@emnapi/core": "^1.7.1",
    "@emnapi/runtime": "^1.7.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.1",
    "prisma": "^6.14.0",
    "supertest": "^7.2.2"
  }
}
