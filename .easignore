# =============================================================================
# .easignore — controls what EAS Build uploads (git repository root)
# =============================================================================
# IMPORTANT: When this file exists, EAS ignores ALL .gitignore files and uses
# ONLY these rules. Keep this list complete.
# Docs: https://docs.expo.dev/build-reference/easignore/
# Archive note: EAS packs from the git root, so sibling packages must be excluded.
# =============================================================================

# ----- Monorepo siblings (not needed for mobile EAS builds) -----
/next_app/
/server/
/.github/

# ----- Dependencies & VCS -----
node_modules/
**/node_modules/
.git/
**/.git/

# ----- Expo / Metro -----
.expo/
**/.expo/
dist/
**/dist/
web-build/
**/web-build/
expo-env.d.ts
.metro-health-check*

# ----- Native projects (regenerated by Prebuild / CNG on EAS) -----
# Local android/ alone is ~2.8GB (build + .cxx caches)
android/
ios/
**/android/
**/ios/
.kotlin/
**/.kotlin/
Pods/
**/Pods/
.gradle/
**/.gradle/
.cxx/
**/.cxx/

# ----- Build / tooling outputs -----
build/
**/build/
.next/
**/.next/
out/
**/out/
.turbo/
**/.turbo/
.vercel/
**/.vercel/
coverage/
**/coverage/
*.tsbuildinfo
*.apk
*.aab
*.ipa
*.jsbundle
*.map

# ----- Logs -----
logs/
*.log
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.*
lerna-debug.*
agent_watcher*.log

# ----- Secrets & local env -----
.env
.env.*
**/.env
**/.env.*
!**/.env.example
firebase-service-account.json
**/firebase-service-account.json
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
credentials.json

# ----- Editor / OS -----
.DS_Store
**/.DS_Store
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.clerk/
**/.clerk/

# ----- Heavy / irrelevant repo root assets -----
*.csv
pexels-*.jpg
*.zip
docs.zip
translate_*.py
fix_*.py
Mission_report*.txt
tasks.md
.mams-rules.md
README.md

# ----- Optional: keep package-lock uploads lean is fine; do NOT ignore -----
# mobile_app/package-lock.json must stay (needed for reproducible installs)
